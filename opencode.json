{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md"
  ],
  "mcp": {
    "knowledge": {
      "type": "local",
      "command": [
        "python",
        "-u",
        "mcp/rag/server.py"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--allowed-origins",
        "127.0.0.1:3000;localhost:3000"
      ],
      "enabled": true
    }
  },
  "permission": {
    "knowledge_*": "deny",
    "playwright_*": "deny"
  },
  "agent": {
    "react-reviewer": {
      "permission": {
        "knowledge_*": "allow",
        "playwright_*": "allow"
      }
    }
  }
}
