{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "permission": {
    "playwright_*": "deny"
  },
  "agent": {
    "react-reviewer": {
      "permission": {
        "playwright_*": "allow"
      }
    }
  }
}
